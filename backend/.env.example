PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# RevenueCat Webhook
REVENUECAT_WEBHOOK_AUTH_BEARER=whsec_your_webhook_secret

# PadelAPI.org - Register at https://padelapi.org/register
# Free plan: 50K requests/month, 2K/day, 10/min. Live scores & advanced stats require paid plan.
PADELAPI_BASE_URL=https://padelapi.org/api
PADELAPI_KEY=your-padelapi-key
PADELAPI_TIMEOUT_MS=10000

# Apify (fallback)
APIFY_TOKEN=your-apify-token
APIFY_ENABLED=false
APIFY_TIMEOUT_MS=15000
APIFY_USE_MOCKS=false

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key
PREMIER_PADEL_CHANNEL_ID=UCkgp8Mf8DbjBoI1_o68__FQ

# Firebase Cloud Messaging (Push Notifications)
# Download service account key from Firebase Console → Project Settings → Service Accounts
# Paste the JSON content here (single line) or set GOOGLE_APPLICATION_CREDENTIALS to file path
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
